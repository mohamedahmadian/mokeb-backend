generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  Admin
  Pilgrim
  MawkibOwner
  HonoraryServant
}

enum MawkibStatus {
  Pending
  Approved
  Rejected
}

enum ReservationStatus {
  Pending
  Confirmed
  Cancelled
  Completed
}

enum RegistrationRequestStatus {
  Pending
  Approved
  Rejected
}

enum HonoraryVolunteerServiceType {
  Transportation
  Cleaning
  Cooking
  Servantship
  FoodSupply
  Other
}

enum HonoraryVolunteerApplicationStatus {
  Pending
  Approved
  Rejected
  Cancelled
}

enum HonoraryVolunteerApplicantType {
  Volunteer
  MawkibOwner
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  mobileNumber String   @unique
  passwordHash String
  province     String?
  city         String?
  description  String?
  whatsapp     String?
  telegram     String?
  bale         String?
  eitaa        String?
  email        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  roles                  UserRole[]
  ownedMawkibs           Mawkib[]                  @relation("MawkibOwner")
  pilgrimReservations    Reservation[]             @relation("Pilgrim")
  reservedByReservations Reservation[]             @relation("ReservedBy")
  registrationRequests   MawkibRegistrationRequest[]
  reviewedHonoraryVolunteerApplications HonoraryVolunteerApplication[] @relation("ReviewedHonoraryVolunteerApplications")
  submittedHonoraryVolunteerApplications HonoraryVolunteerApplication[] @relation("SubmittedHonoraryVolunteerApplications")
  reservationReviewsAuthored           ReservationReview[] @relation("ReservationReviewAuthor")
  reservationReviewsReplied              ReservationReview[] @relation("ReservationReviewReplier")
  mawkibFeedbacksAuthored              MawkibFeedback[] @relation("MawkibFeedbackAuthor")
  mawkibFeedbacksReplied               MawkibFeedback[] @relation("MawkibFeedbackReplier")

  @@map("users")
}

model Role {
  id   Int      @id @default(autoincrement())
  name RoleName @unique

  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId Int
  roleId Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

enum MawkibCountry {
  Iran
  Iraq
}

enum MawkibCity {
  Mashhad
  Qom
  Najaf
  Karbala
}

model Mawkib {
  id               Int          @id @default(autoincrement())
  name             String
  address          String
  latitude         Float?
  longitude        Float?
  phoneNumber      String
  description      String?
  facilities       String?
  services         String?
  serviceStartDate DateTime?    @db.Date
  serviceEndDate   DateTime?    @db.Date
  maleCapacity     Int
  femaleCapacity   Int
  imageUrl         String?
  distanceToShrine String?
  lunchReception       Boolean  @default(false)
  breakfastReception   Boolean  @default(false)
  dinnerReception      Boolean  @default(false)
  bathroom             Boolean  @default(false)
  laundry              Boolean  @default(false)
  parking              Boolean  @default(false)
  internet             Boolean  @default(false)
  familyFriendly       Boolean  @default(false)
  maxReservationDays   Int?
  country              MawkibCountry @default(Iran)
  mawkibCity           MawkibCity?
  rules                String?
  telegramChannel      String?
  whatsapp             String?
  bale                 String?
  eitaa                String?
  websiteUrl           String?
  defaultCheckInTime   String       @default("14:00")
  defaultCheckOutTime  String       @default("11:00")
  ownerUserId      Int
  status           MawkibStatus @default(Pending)
  createdAt        DateTime     @default(now())

  owner        User          @relation("MawkibOwner", fields: [ownerUserId], references: [id])
  reservations Reservation[]
  dailyInventory MawkibDailyInventory[]
  honoraryVolunteerApplications HonoraryVolunteerApplication[]
  feedbacks    MawkibFeedback[]

  @@map("mawkibs")
}

model MawkibDailyInventory {
  id             Int      @id @default(autoincrement())
  mawkibId       Int
  date           DateTime @db.Date
  reservedMale   Int      @default(0)
  reservedFemale Int      @default(0)
  updatedAt      DateTime @updatedAt

  mawkib Mawkib @relation(fields: [mawkibId], references: [id], onDelete: Cascade)

  @@unique([mawkibId, date])
  @@index([mawkibId, date])
  @@map("mawkib_daily_inventory")
}

model Reservation {
  id              Int               @id @default(autoincrement())
  mawkibId        Int
  pilgrimUserId   Int
  reservedByUserId Int
  reservationDate    DateTime          @db.Date
  reservationEndDate DateTime          @db.Date
  plannedCheckInTime  String?
  plannedCheckOutTime String?
  actualCheckInAt     DateTime?
  actualCheckOutAt    DateTime?
  maleGuestCount     Int
  femaleGuestCount   Int
  trackingCode       String            @unique
  pilgrimMobile   String
  companions         String?
  description        String?
  cancellationNote   String?
  status             ReservationStatus @default(Pending)
  createdAt       DateTime          @default(now())

  mawkib      Mawkib @relation(fields: [mawkibId], references: [id])
  pilgrim     User   @relation("Pilgrim", fields: [pilgrimUserId], references: [id])
  reservedBy  User   @relation("ReservedBy", fields: [reservedByUserId], references: [id])
  review      ReservationReview?

  @@index([mawkibId, reservationDate])
  @@map("reservations")
}

model ReservationReview {
  id              Int       @id @default(autoincrement())
  reservationId   Int       @unique
  authorUserId    Int
  content         String
  adminReply      String?
  repliedAt       DateTime?
  repliedByUserId Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  author      User        @relation("ReservationReviewAuthor", fields: [authorUserId], references: [id])
  repliedBy   User?       @relation("ReservationReviewReplier", fields: [repliedByUserId], references: [id])

  @@map("reservation_reviews")
}

model MawkibRegistrationRequest {
  id          Int                       @id @default(autoincrement())
  ownerUserId Int
  ownerName   String
  phoneNumber String
  mawkibName  String
  address     String
  latitude    Float?
  longitude   Float?
  capacity    Int
  description String?
  status      RegistrationRequestStatus @default(Pending)
  createdAt   DateTime                  @default(now())

  owner User @relation(fields: [ownerUserId], references: [id])

  @@map("mawkib_registration_requests")
}

model HonoraryVolunteerApplication {
  id                      Int                                @id @default(autoincrement())
  trackingCode            String                             @unique
  applicantType           HonoraryVolunteerApplicantType     @default(Volunteer)
  firstName               String
  lastName                String
  mobileNumber            String
  province                String?
  city                    String?
  mawkibId                Int?
  submittedByUserId       Int?
  description             String?
  serviceTypes            HonoraryVolunteerServiceType[]
  serviceDescription      String?
  availabilityStartDate   DateTime                           @db.Date
  availabilityEndDate     DateTime                           @db.Date
  availabilityDescription String?
  status                  HonoraryVolunteerApplicationStatus @default(Pending)
  reviewNote              String?
  reviewedAt              DateTime?
  reviewedByUserId        Int?
  createdAt               DateTime                           @default(now())

  mawkib       Mawkib? @relation(fields: [mawkibId], references: [id], onDelete: SetNull)
  submittedBy  User?   @relation("SubmittedHonoraryVolunteerApplications", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  reviewedBy   User?   @relation("ReviewedHonoraryVolunteerApplications", fields: [reviewedByUserId], references: [id])

  @@map("honorary_volunteer_applications")
}

model MawkibFeedback {
  id              Int       @id @default(autoincrement())
  mawkibId        Int
  authorUserId    Int
  content         String
  ownerReply      String?
  repliedAt       DateTime?
  repliedByUserId Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  mawkib    Mawkib @relation(fields: [mawkibId], references: [id])
  author    User   @relation("MawkibFeedbackAuthor", fields: [authorUserId], references: [id])
  repliedBy User?  @relation("MawkibFeedbackReplier", fields: [repliedByUserId], references: [id])

  @@index([mawkibId, createdAt])
  @@index([authorUserId, createdAt])
  @@map("mawkib_feedbacks")
}
